<IfModule mod_rewrite.c>
  RewriteEngine On

  # Route every legacy logo filename to the cleaned transparent SVG logo.
  RewriteRule ^images/(logo-wide|logo-medium|logo-small|logo-big|drn-logo)\.png$ images/drn-logo.svg [L]
</IfModule>

<IfModule mod_mime.c>
  AddType image/svg+xml .svg
</IfModule>

<IfModule mod_headers.c>
  # HTML should not be cached aggressively
  <FilesMatch "\.(html?)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Cache static assets aggressively (we use versioned URLs)
  <FilesMatch "\.(?:css|js|png|jpe?g|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Keep the new SVG logo fresh while the logo change propagates.
  <Files "drn-logo.svg">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>

  Header append Vary "Accept-Encoding"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
